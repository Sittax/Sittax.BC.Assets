# =============================================================================
# Central de Conhecimento — variáveis de ambiente
# Copie para .env e preencha. NENHUM valor real entra em código ou repositório.
# A aplicação valida tudo na inicialização (src/lib/config.ts) e falha ao subir
# com mensagem clara se algo estiver ausente ou inválido.
# =============================================================================

# Conexão com o Postgres como role da aplicação (central_app — não-owner, sem
# BYPASSRLS; criada pela migração de policies RLS).
# Ex.: postgres://central_app:<senha>@localhost:5432/central
DATABASE_URL=

# Conexão de administração usada APENAS por migração, seed e setup de testes
# (owner do schema). Ex.: postgres://central:<senha>@localhost:5432/central
DATABASE_ADMIN_URL=

# Segredo do cookie de sessão (iron-session). Mínimo 32 caracteres aleatórios.
SESSION_SECRET=

# As 6 URLs base do SSO dos sistemas Sittax, separadas por vírgula, TODAS HTTPS
# (exatamente 6 — em desenvolvimento, repetir a URL de homologação 6x).
SSO_BASE_URLS=

# Timeout por sistema (ms) na sequência de autenticação SSO.
SSO_TIMEOUT_MS=3000

# Teto total (ms) da tentativa de login SSO — estourou, interrompe a sequência.
SSO_TOTAL_TIMEOUT_MS=10000

# Janela deslizante de inatividade da sessão (dias).
SESSION_IDLE_DAYS=7

# Teto absoluto da sessão (dias) — contado do login, independe de atividade.
SESSION_MAX_DAYS=30

# --- MinIO / Storage de imagens (Feature 002) ---
# Endpoint do MinIO (ex.: http://localhost:9000 em desenvolvimento).
MINIO_ENDPOINT=

# Credenciais de acesso ao MinIO.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Nome do bucket onde as imagens são armazenadas.
MINIO_BUCKET=central-conhecimento

# Path-style (true em desenvolvimento com MinIO local).
MINIO_FORCE_PATH_STYLE=true

# --- Seed (scripts/seed.ts) ---
# Senha dos usuários locais do seed de DESENVOLVIMENTO (dev/master de teste).
# SEED_USER_PASSWORD=central12345
# Bootstrap de produção (npm run db:seed -- --bootstrap): primeiro Master.
# SEED_MASTER_EMAIL=
# SEED_MASTER_PASSWORD=
